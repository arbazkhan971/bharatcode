# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Build output (make build) and GoReleaser artifacts.
/bin/
/dist/

# Stray local builds of the binary at the repo root (e.g. `go build -o`).
/bharatcode
/bharatcode-test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env

# Editor/IDE
# .idea/
# .vscode/

# macOS
.DS_Store

# Claude Code / agent session state
.claude/

# Local Playwright MCP state (browser console logs and page snapshots).
.playwright-mcp/

# Local browser/TUI screenshots and generated site captures dropped at the
# repo root by docs/preview tooling. Scoped to the root with a leading slash
# so intentional images under assets/ stay tracked.
/*-live.jpeg
/tui-*.png
/comparison-check.jpeg
/full-redesign.jpeg
/new-hero.jpeg
/ref-*.jpeg
/site-current.jpeg
/bharatcode-home.png
/tictactoe-game.png
