{
  "document": {
    "block_prefix": "",
    "block_suffix": "",
    "color": "#e8e2d6",
    "margin": 0
  },
  "block_quote": {
    "color": "#8c857a",
    "indent": 1,
    "indent_token": "▍ "
  },
  "paragraph": {},
  "list": {
    "level_indent": 2
  },
  "heading": {
    "block_suffix": "\n",
    "color": "#f0a85a",
    "bold": true
  },
  "h1": {
    "prefix": "# ",
    "color": "#f0a85a",
    "bold": true
  },
  "h2": {
    "prefix": "## ",
    "color": "#f0a85a",
    "bold": true
  },
  "h3": {
    "prefix": "### ",
    "color": "#e8c79a",
    "bold": true
  },
  "h4": {
    "prefix": "#### ",
    "color": "#e8c79a",
    "bold": true
  },
  "h5": {
    "prefix": "##### ",
    "color": "#8c857a",
    "bold": true
  },
  "h6": {
    "prefix": "###### ",
    "color": "#8c857a",
    "bold": false
  },
  "text": {},
  "strikethrough": {
    "crossed_out": true
  },
  "emph": {
    "italic": true
  },
  "strong": {
    "bold": true
  },
  "hr": {
    "color": "#5c564c",
    "format": "\n──────────\n"
  },
  "item": {
    "block_prefix": "• "
  },
  "enumeration": {
    "block_prefix": ". "
  },
  "task": {
    "ticked": "[✓] ",
    "unticked": "[ ] "
  },
  "link": {
    "color": "#58a6ff",
    "underline": false
  },
  "link_text": {
    "color": "#58a6ff",
    "bold": false
  },
  "image": {
    "color": "#58a6ff",
    "underline": false
  },
  "image_text": {
    "color": "#8c857a",
    "format": "Image: {{.text}} →"
  },
  "code": {
    "color": "#f0a85a",
    "background_color": "#211d18"
  },
  "code_block": {
    "color": "#cfc8ba",
    "margin": 0,
    "chroma": {
      "text": {
        "color": "#cfc8ba"
      },
      "error": {
        "color": "#f4efe6",
        "background_color": "#6e3b34"
      },
      "comment": {
        "color": "#736c60"
      },
      "comment_preproc": {
        "color": "#9a9286"
      },
      "keyword": {
        "color": "#d99a6a"
      },
      "keyword_reserved": {
        "color": "#d99a6a"
      },
      "keyword_namespace": {
        "color": "#d99a6a"
      },
      "keyword_type": {
        "color": "#7fbf8a"
      },
      "operator": {
        "color": "#b3a994"
      },
      "punctuation": {
        "color": "#b3a994"
      },
      "name": {
        "color": "#cfc8ba"
      },
      "name_builtin": {
        "color": "#7fbf8a"
      },
      "name_tag": {
        "color": "#d99a6a"
      },
      "name_attribute": {
        "color": "#7fbf8a"
      },
      "name_class": {
        "color": "#e8c79a",
        "bold": true
      },
      "name_constant": {
        "color": "#e8c79a"
      },
      "name_decorator": {
        "color": "#e8c79a"
      },
      "name_exception": {
        "color": "#e8c79a"
      },
      "name_function": {
        "color": "#e3b079"
      },
      "name_other": {},
      "literal": {},
      "literal_number": {
        "color": "#9ec4ad"
      },
      "literal_date": {},
      "literal_string": {
        "color": "#a8b06f"
      },
      "literal_string_escape": {
        "color": "#9ec4ad"
      },
      "generic_deleted": {
        "color": "#d98a8a"
      },
      "generic_emph": {
        "italic": true
      },
      "generic_inserted": {
        "color": "#6fbf73"
      },
      "generic_strong": {
        "bold": true
      },
      "generic_subheading": {
        "color": "#736c60"
      },
      "background": {
        "background_color": "#1a1714"
      }
    }
  },
  "table": {},
  "definition_list": {},
  "definition_term": {},
  "definition_description": {
    "block_prefix": "\n🠶 "
  },
  "html_block": {},
  "html_span": {}
}
